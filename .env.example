DB_URI=mongodb://127.0.0.1:27017/express_base
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Health & Business Pulse (opcional). Sin PULSE_BEARER_TOKEN no se monta GET /internal/pulse
PULSE_BEARER_TOKEN=change-me-pulse-service-token
PULSE_PRODUCT_NAME=express-base
PULSE_AI_CONTEXT=
# JSON objeto, ej: {"kpiExample":42}
PULSE_BUSINESS_METRICS_JSON=
PULSE_PROBE_TIMEOUT_MS=150
PULSE_COLLECTION_TIMEOUT_MS=300
