{
  "name": "express-base",
  "version": "1.0.4",
  "description": "Base API for Express projects with Typescript",
  "main": "server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests --detectOpenHandles",
    "test:watch": "jest --watch",
    "prepare": "husky install",
    "test:cov": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "preset": "ts-jest",
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ]
  },
  "overrides": {
    "braces": ">=3.0.3",
    "form-data": ">=4.0.0",
    "minimatch": ">=9.0.5",
    "glob": ">=10.4.5",
    "qs": ">=6.11.0",
    "tough-cookie": ">=4.1.3",
    "node-notifier": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "braces": ">=3.0.3",
      "form-data": ">=4.0.0",
      "minimatch": ">=9.0.5",
      "glob": ">=10.4.5",
      "qs": ">=6.11.0",
      "tough-cookie": ">=4.1.3",
      "node-notifier": ">=10.0.0"
    }
  },
  "keywords": [
    "express",
    "typescript",
    "nodejs",
    "api",
    "rest",
    "base-project"
  ],
  "author": "Agustin Avellaneda",
  "repository": {
    "type": "git",
    "url": "https://github.com/nitdraig/express-base.git"
  },
  "bugs": {
    "url": "https://github.com/nitdraig/express-base/issues"
  },
  "homepage": "https://github.com/nitdraig/express-base#readme",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cross-env": "^10.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^9.10.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.5",
    "nodemon": "^3.1.9",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth": "^2.0.0",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "web-push": "^1.0.2",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.10",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
